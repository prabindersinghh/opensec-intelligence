{
  "name": "opensec-intelligence",
  "version": "3.2.0",
  "description": "Local-first, multi-agent AI security scanner. Finds vulnerabilities. Writes the patches. Free forever.",
  "type": "module",
  "bin": {
    "opensec": "./bin/opensec.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:cli": "playwright test tests/e2e/cli.spec.ts",
    "test:e2e:api": "playwright test tests/e2e/api.spec.ts",
    "test:all": "vitest run && playwright test tests/e2e/cli.spec.ts",
    "lint": "tsc --noEmit",
    "start": "node dist/bin/cmdr.js",
    "assets": "npm run build && node scripts/generate-readme-assets.js",
    "postinstall": "node bin/postinstall.js",
    "eval": "npx tsx evals/run-evals.ts",
    "eval:report": "npx tsx evals/report.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "bin/opensec.js",
    "bin/postinstall.js",
    "demo",
    "docs/screenshots",
    "scripts/generate-readme-assets.js",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "homepage": "https://github.com/prabindersinghh/opensec-intelligence#readme",
  "bugs": {
    "url": "https://github.com/prabindersinghh/opensec-intelligence/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "highlight.js": "^11.11.1",
    "ink": "npm:@jrichman/ink@6.6.7",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lowlight": "^3.3.0",
    "marked": "^14.0.0",
    "marked-terminal": "^7.2.0",
    "ora": "^8.0.0",
    "react": "^19.2.0",
    "smol-toml": "^1.6.1",
    "string-width": "^8.1.0",
    "strip-ansi": "^7.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "security",
    "vulnerability-scanner",
    "ai-security",
    "ollama",
    "local-llm",
    "devsecops",
    "owasp",
    "sast",
    "code-security",
    "secrets-detection",
    "agent",
    "multi-agent",
    "cli"
  ],
  "author": "Prabinder Singh <prabindersinghh@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/prabindersinghh/opensec-intelligence.git"
  }
}
